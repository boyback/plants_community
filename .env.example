# ============== 数据库 ==============
# MySQL 连接字符串
# 格式:mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:YOUR_PASSWORD@127.0.0.1:3306/plants_community"
MYSQL_ROOT_PASSWORD="YOUR_MYSQL_ROOT_PASSWORD"
MYSQL_DATABASE="plants_community"
MYSQL_PORT="3307"

# ============== 认证 ==============
# JWT 签名密钥,至少 32 字节随机串
JWT_SECRET="please-change-me-to-a-long-random-string-32chars-minimum"
AUTH_COOKIE_NAME="rouyou_token"
AUTH_COOKIE_MAX_AGE="2592000"

# ============== 站点 / 网络 ==============
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
HTTP_PORT="80"
HTTPS_PORT="443"
CORS_ORIGIN="http://localhost:3000"

# ============== 支付(可选) ==============
# mock | alipay | wechat | real
PAYMENT_GATEWAY="mock"

ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY_PEM=""
ALIPAY_PUBLIC_KEY_PEM=""
ALIPAY_GATEWAY="https://openapi.alipay.com/gateway.do"
ALIPAY_NOTIFY_URL=""
ALIPAY_RETURN_URL=""
ALIPAY_SIGN_TYPE="RSA2"

WECHAT_APPID=""
WECHAT_MCHID=""
WECHAT_SERIAL_NO=""
WECHAT_PRIVATE_KEY_PEM=""
WECHAT_API_V3_KEY=""
WECHAT_NOTIFY_URL=""

# ============== 微信登录(可选) ==============
WECHAT_LOGIN_APP_ID=""
WECHAT_LOGIN_APP_SECRET=""
WECHAT_LOGIN_REDIRECT_URI="http://localhost:3000/api/auth/wechat/callback"

WECHAT_MP_APP_ID=""
WECHAT_MP_APP_SECRET=""
WECHAT_MP_REDIRECT_URI="http://localhost:3000/api/auth/wechat/h5/callback"

# ============== 邮箱验证码(可选) ==============
# OTP_DRIVER=mock | smtp
OTP_DRIVER="mock"
SMTP_HOST=""
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_NAME="肉友社"

# ============== 站长平台验证(可选) ==============
SITE_VERIFICATION_BAIDU=""
SITE_VERIFICATION_GOOGLE=""
SITE_VERIFICATION_BING=""
SITE_VERIFICATION_360=""
SITE_VERIFICATION_SOGOU=""

# ============== 百度普通收录 API 推送(可选) ==============
BAIDU_PUSH_TOKEN=""

# ============== 上传存储 ==============
# local | qiniu
UPLOAD_DRIVER="local"

QINIU_ACCESS_KEY=""
QINIU_SECRET_KEY=""
QINIU_BUCKET=""
QINIU_DOMAIN=""
QINIU_REGION="z0"

# ============== 审核功能 ==============
REVIEW_FILTER_ENABLED="0"

# ============== AI 图鉴助手 ==============
# auto | gemini | openrouter | local
AI_PROVIDER="local"
AI_TIMEOUT_MS="12000"

GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openrouter/free"
