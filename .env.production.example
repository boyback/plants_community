# =====================================================================
# 生产环境变量模板。
#   1. cp .env.production.example .env
#   2. 把 ??? 替换成你自己的密钥(JWT_SECRET、MYSQL 密码、支付宝/微信)
#   3. docker compose up -d --build
# =====================================================================

# ----- MySQL -----
MYSQL_ROOT_PASSWORD=???_change_me_random_strong_password_???
MYSQL_DATABASE=plants_community
# 本地若想暴露 MySQL 端口给外面调试,改这里(默认 3307,生产建议把 ports: 注释)
MYSQL_PORT=3307

# ----- 应用通用 -----
# 一定要换成自己的强随机字符串(32+ 字符)
JWT_SECRET=???_change_me_to_random_64_chars_???
AUTH_COOKIE_NAME=rouyou_token
AUTH_COOKIE_MAX_AGE=2592000

# ----- Nginx 端口(默认 80/443) -----
HTTP_PORT=80
HTTPS_PORT=443

# ----- CORS(Go 端用,允许哪个 Origin 的请求带 cookie) -----
CORS_ORIGIN=https://plantcommunity.cn

# =====================================================================
# 支付(可选)
# =====================================================================

# mock | alipay | wechat | real(支付宝+微信都走真实)
PAYMENT_GATEWAY=mock

# Alipay sandbox / production
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PEM=
ALIPAY_PUBLIC_KEY_PEM=
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_NOTIFY_URL=https://plantcommunity.cn/api/payments/alipay/webhook
ALIPAY_RETURN_URL=https://plantcommunity.cn/checkout/done

# 微信(Native 扫码支付)
WECHAT_APPID=
WECHAT_MCHID=
WECHAT_SERIAL_NO=
WECHAT_PRIVATE_KEY_PEM=
WECHAT_API_V3_KEY=
WECHAT_NOTIFY_URL=https://plantcommunity.cn/api/payments/wechat/webhook

# 微信登录(开放平台「网站应用」 — PC 扫码)
# 申请地址:https://open.weixin.qq.com,授权回调域 = plantcommunity.cn
# 任一组留空则前端按钮自动隐藏
WECHAT_LOGIN_APP_ID=
WECHAT_LOGIN_APP_SECRET=
WECHAT_LOGIN_REDIRECT_URI=https://plantcommunity.cn/api/auth/wechat/callback

# 微信公众号网页授权(微信内 H5 一键登录)
# 服务号 + 已认证 + 接口权限「网页授权获取用户基本信息」
WECHAT_MP_APP_ID=
WECHAT_MP_APP_SECRET=
WECHAT_MP_REDIRECT_URI=https://plantcommunity.cn/api/auth/wechat/h5/callback

# 邮箱验证码登录(通用 SMTP)
# OTP_DRIVER=mock(默认,console 打印) | smtp(真实发送)
OTP_DRIVER=smtp
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@plantcommunity.cn
SMTP_PASS=
SMTP_FROM_NAME=肉友社

# 站长平台验证(从各平台 HTML 标签验证页面复制 content 值)
# 修改后 docker compose restart next 即生效(server-side 读取,无需重新 build)
SITE_VERIFICATION_BAIDU=
SITE_VERIFICATION_GOOGLE=
SITE_VERIFICATION_BING=
SITE_VERIFICATION_360=
SITE_VERIFICATION_SOGOU=

# 百度普通收录 API 推送(token 来自 ziyuan.baidu.com 普通收录 → API 提交)
BAIDU_PUSH_TOKEN=

# =====================================================================
# 上传存储 driver
# 'local' (默认) — 写入容器内 /app/public/uploads,通过 ./data/uploads 持久化
# 'qiniu' — 走七牛云 Kodo
# =====================================================================
UPLOAD_DRIVER=local

# 七牛云配置(UPLOAD_DRIVER=qiniu 时必填)
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
# 已绑定的 CDN/源站域名,带协议,如 https://cdn.plantcommunity.cn
QINIU_DOMAIN=
# 区域(默认 z0=华东):z0/z1/z2/na0/as0
QINIU_REGION=z0

# 帖子审核功能开关(需要 schema 已同步 reviewStatus 列)
REVIEW_FILTER_ENABLED=0
