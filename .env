# 请稍后用你的 MySQL root 密码替换其中的 YOUR_ROOT_PASSWORD
DATABASE_URL="mysql://root:root123456@127.0.0.1:3306/plants_community"

JWT_SECRET="rouyou-community-demo-secret-please-change-this-in-production-xxx"
AUTH_COOKIE_NAME="rouyou_token"
AUTH_COOKIE_MAX_AGE="2592000"

# =========================================================================
# Alipay sandbox 配置(请把这对 key 换成你自己的,已泄露的请在开放平台轮换)
# =========================================================================
# 开关: mock (默认) | alipay | wechat | real(支付宝+微信都走真实通道)
PAYMENT_GATEWAY=real

# 沙箱 AppId
ALIPAY_APP_ID=9021000163641363

# 应用私钥(PKCS#1 原始格式,由 SDK 自动包裹 BEGIN/END 头尾)
ALIPAY_PRIVATE_KEY_

# 支付宝公钥(沙箱下载的,由 SDK 自动包裹 BEGIN/END 头尾)
# 注:你贴的这串看起来是 **应用公钥**,不是「支付宝公钥」。
# 正式联调前务必从开放平台沙箱「查看支付宝公钥」下载对应的公钥替换。
ALIPAY_PUBLIC_KEY_

# 网关
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
# 生产网关(正式上线时切换):
# ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 回调(本地调试可用 ngrok / Cloudflare Tunnel 代理出去)
ALIPAY_NOTIFY_URL=http://localhost:3000/api/payments/alipay/webhook
ALIPAY_RETURN_URL=http://localhost:3000/checkout/done

# =========================================================================
# 微信支付 Native(扫码支付)
# =========================================================================
# 公众号 / 小程序 / 开放平台 APPID(任一可收款的 appid)
WECHAT_APPID=
# 商户号
WECHAT_MCHID=
# 商户 API 证书序列号(apiclient_cert.pem 的序列号)
WECHAT_SERIAL_NO=
# 商户 API 私钥 PEM(apiclient_key.pem 的内容;支持单行 base64、\n 转义或完整 PEM)
WECHAT_PRIVATE_KEY_PEM=
# APIv3 密钥(32 位,商户平台自己设的那串)
WECHAT_API_V3_KEY=
# 回调地址(必须 https 公网可达)
WECHAT_NOTIFY_URL=http://localhost:3000/api/payments/wechat/webhook

# =========================================================================
# 微信登录(开放平台「网站应用」 — PC 扫码)
# 申请地址:https://open.weixin.qq.com,授权回调域 = plantcommunity.cn
# 留空则前端按钮自动隐藏
# =========================================================================
WECHAT_LOGIN_APP_ID=
WECHAT_LOGIN_APP_SECRET=
# 扫码登录回调地址(站内路径,必须 https 公网可达;dev 期可用 ngrok)
WECHAT_LOGIN_REDIRECT_URI=http://localhost:3000/api/auth/wechat/callback

# =========================================================================
# 微信公众号网页授权(微信内 H5 登录)
# 服务号 + 已认证 + 接口权限「网页授权获取用户基本信息」
# 留空则微信内不展示该入口
# =========================================================================
WECHAT_MP_APP_ID=
WECHAT_MP_APP_SECRET=
# 公众号网页授权回调地址(必须备案域名 + https,授权回调域必须配置)
WECHAT_MP_REDIRECT_URI=http://localhost:3000/api/auth/wechat/h5/callback

# =========================================================================
# 邮箱验证码登录(SMTP)
# OTP_DRIVER=mock 时验证码只打 console,无需配置 SMTP
# OTP_DRIVER=smtp 时下面 SMTP_* 都需要填
# 通用 SMTP 协议,腾讯/新浪/网易/263 等任何企业邮箱都能用
# =========================================================================
OTP_DRIVER=smtp
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=admin@plantcommunity.cn
SMTP_PASS=EwZzeF43NyDq7f3i
SMTP_FROM_NAME=肉友社

# =========================================================================
# 站长平台验证 code(从对应平台 HTML 标签验证页面复制 content 值)
# 留空则不输出对应 meta 标签
# =========================================================================
# 百度站长 (https://ziyuan.baidu.com)
SITE_VERIFICATION_BAIDU=codeva-pZaG8y4Efk
# Google Search Console (https://search.google.com/search-console)
SITE_VERIFICATION_GOOGLE=3rKG-1ar7nhjQW3-bHTpDO86q4hfzK-nIJlKGbo1G2k
# Bing Webmaster (https://www.bing.com/webmasters)
SITE_VERIFICATION_BING=
# 360 站长 (https://zhanzhang.so.com)
SITE_VERIFICATION_360=2df2d053d0df4419e9711058dafa6850
# 搜狗站长 (https://zhanzhang.sogou.com)
SITE_VERIFICATION_SOGOU=C6yWc7RCbh

# =========================================================================
# 百度普通收录 API 推送(发帖/审核通过 → 主动推送到百度,1 分钟内被爬)
# token 来自 ziyuan.baidu.com 普通收录 → API 提交
