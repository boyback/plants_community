    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@types/nodemailer": "^8.0.0",
    "alipay-sdk": "^4.14.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "clsx": "2.1.1",
    "heic-convert": "^2.1.0",
    "html-to-text": "^9.0.5",
    "isomorphic-dompurify": "^2.30.0",
    "jose": "^6.2.3",
    "next": "14.2.5",
    "nodemailer": "^8.0.7",
    "photoswipe": "^5.4.4",
