{
  "name": "plants-community",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "test": "node --test tests/",
    "i18n:scan": "node scripts/i18n-scan.mjs",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "db:reseed": "prisma db push --force-reset --accept-data-loss && tsx prisma/seed.ts",
    "setup": "prisma db push && tsx prisma/seed.ts",
    "alipay:probe": "node -r dotenv/config scripts/alipay-probe.mjs",
    "wechat:probe": "node -r dotenv/config scripts/wechat-probe.mjs",
    "feed:refresh": "node -r dotenv/config scripts/feed-refresh.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
