// 肉友社 · 数据库 Schema
// 数据库:MySQL 8 | ORM:Prisma
// 设计原则:保持前端现有类型的字段名尽可能一致,便于 API 直接对上。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============== 用户 ==============

model User {
  id           String   @id @default(cuid())
  name         String   @unique
  passwordHash String
  avatar       String   @default("")
  bio          String?  @db.Text
  level        Int      @default(1)
  exp          Int      @default(0) // 经验值,达到阈值自动升级
  joinedAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // 签到状态
  lastSignInAt DateTime?
  signInStreak Int       @default(0)

  // 积分余额(冗余字段,流水累加结果)
  pointsBalance Int @default(0)

  // 大会员
  vipExpireAt DateTime? // 到期时间;>now 即 VIP
  vipLifetime Boolean   @default(false) // 终身大会员
  vipFirstAt  DateTime? // 第一次开通时间(用于股东标识)

  // 隐私开关:是否公开 关注列表 / 粉丝列表(默认均公开,符合社区默认)
  privacyShowFollowing Boolean @default(true)
  privacyShowFollowers Boolean @default(true)

  // 管理员角色:user(默认) / moderator(版主) / admin(超管)
  role        UserRole  @default(user)
  // 封禁:若 bannedUntil > now 则无法登录 / 发帖 / 评论;null 或过去时间 = 未封禁
  bannedUntil DateTime?
  banReason   String?   @db.Text

  // 语言偏好 / 节日主题开关
  locale         String  @default("zh-CN") // zh-CN / zh-TW / en / ja / ko
  // 用户主动关闭的主题 slug 的 JSON array,如 ["christmas","halloween"]。
  // 最长 255 字符足够装下 50+ 个 slug
  disabledThemes String  @default("[]")
  // 若为 true,彻底关闭所有节日主题
  themesDisabled Boolean @default(false)

  // 当前装扮(指向 SkinItem.id,可空)
  equipBubbleId   String? // 评论气泡
  equipReactionId String? // 点赞按钮皮肤
  equipStickerId  String? // 表情包(主题)
  equipPendantId  String? // 昵称挂件(头像框)

  // 关系
  posts            Post[]
  comments         Comment[]
  likes            PostLike[]
  followers        Follow[]        @relation("Followees")
  following        Follow[]        @relation("Followers")
  badges           UserBadge[]
  notifications    Notification[]  @relation("NotifRecipient")
  notifFromMe      Notification[]  @relation("NotifSender")
  reports          Report[]        @relation("ReportReporter")
  postViews        PostView[]
  speciesRatings   SpeciesRating[]
  sentMessages     Message[]       @relation("MessageFrom")
  receivedMessages Message[]       @relation("MessageTo")
  drafts           Draft[]
  votes            VoteRecord[]
  collects         PostCollect[]
  events           EventAttendee[]

  // 新增关系
  pointsLedger   PointsLedger[]
  expLedger      ExpLedger[]
  activityLedger ActivityLedger[]
  monthlyStats   MonthlyActivity[]
  taskProgress   TaskProgress[]
  rewardClaims   ActivityRewardClaim[]
  productsListed Product[]             @relation("ProductSeller")
  ordersAsBuyer  Order[]               @relation("OrderBuyer")
  ordersAsSeller Order[]               @relation("OrderSeller")
  payments       Payment[]
  ownedSkins     UserSkin[]
  vipOrders      VipOrder[]

  // 拍卖 / 地址簿
  addresses           Address[]
  auctionsListed      Auction[]            @relation("AuctionSeller")
  auctionsWon         Auction[]            @relation("AuctionWinner")
  bids                Bid[]                @relation("BidUser")
  auctionParticipants AuctionParticipant[] @relation("AuctionParticipantUser")

  // 关注板块(可跨三级:科/属/品种)
  boardFollows BoardFollow[]

  @@map("users")
}

model Follow {
  followerId String
  followeeId String
  createdAt  DateTime @default(now())

  follower User @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  followee User @relation("Followees", fields: [followeeId], references: [id], onDelete: Cascade)

  @@id([followerId, followeeId])
  @@index([followeeId])
  @@map("follows")
}

// ============== 徽章 ==============

model Badge {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  icon        String
  description String @db.Text
  orderIdx    Int    @default(0)

  users UserBadge[]

  @@map("badges")
}

model UserBadge {
  userId     String
  badgeId    String
  obtained   Boolean   @default(false)
  obtainedAt DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
  @@index([badgeId])
  @@map("user_badges")
}

// ============== 板块 ==============

model Board {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  description String @db.Text
  cover       String
  icon        String
  members     Int    @default(0)
  orderIdx    Int    @default(0)

  posts Post[]

  @@map("boards")
}

// ============== 帖子 ==============

enum PostType {
  rich
  short
  vote
  video
  event
  help // 求助贴:附带悬赏 + 紧急度 + 采纳机制
  journal // 生命周期 / 成长日志:时间线记录植物各阶段
}

enum JournalEndReason {
  alive // 仍在养(默认,未结束时)
  withered // 枯死
  gifted // 送人 / 转手
  finished // 正常结束(如开花结束、季节性度过)
  other
}

enum JournalStage {
  germinate // 发芽
  growing // 成长
  flowering // 开花
  fruiting // 结果
  withering // 枯萎
  repot // 换盆
  cutting // 扦插
  summer // 度夏
  winter // 越冬
  pest // 虫害
  watering // 浇水/施肥
  other
}

enum HelpUrgency {
  low // 不急
  normal // 一般
  high // 紧急
}

model Post {
  id           String    @id @default(cuid())
  type         PostType
  title        String
  // 富文本三套字段:JSON 是源,HTML 是渲染缓存,plain 是搜索/摘要用纯文本
  content      String    @db.LongText // 已 sanitize 的 HTML(渲染缓存)
  contentJson  String?   @db.LongText // ProseMirror JSON 字符串(权威源)
  contentText  String?   @db.Text // 纯文本摘要,做搜索/列表预览用
  cover        String?
  images       String?   @db.Text // JSON array string
  videoUrl     String?
  tags         String?   @db.Text // JSON array string
  views        Int       @default(0)
  shares       Int       @default(0)
  // 推荐算法产出的热度分(定时刷);越大越靠前
  hotScore     Float     @default(0)
  // 缓存 top 评论数 / 收藏数,用于算分(冗余字段定时刷)
  // 软删除
  deleted      Boolean   @default(false)
  deletedAt    DateTime?
  deletedBy    String? // 管理员 id
  deleteReason String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  authorId   String
  // 三级分类(Category 必填,Genus/Species 可选)
  categoryId String?
  genusId    String?
  speciesId  String?
  // 旧 Board(保留字段,但关系已断,新业务不再依赖)
  boardId    String?
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category   Category? @relation(fields: [categoryId], references: [id])
  genus      Genus?    @relation(fields: [genusId], references: [id])
  species    Species?  @relation(fields: [speciesId], references: [id])
  board      Board?    @relation(fields: [boardId], references: [id])

  // 帖子类型扩展
  vote    Vote?
  event   Event?
  help    HelpRequest?
  journal Journal?

  comments Comment[]
  likes    PostLike[]
  collects PostCollect[]
  views_   PostView[]

  @@index([categoryId, createdAt])
  @@index([genusId, createdAt])
  @@index([speciesId, createdAt])
  @@index([boardId, createdAt])
  @@index([authorId])
  // 推荐流按 hotScore 排序的高频查询索引
  @@index([deleted, hotScore])
  @@map("posts")
}

model Vote {
  id       String   @id @default(cuid())
  postId   String   @unique
  question String
  multi    Boolean  @default(false)
  deadline DateTime

  post    Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  options VoteOption[]
  records VoteRecord[]

  @@map("votes")
}

model VoteOption {
  id       String @id @default(cuid())
  voteId   String
  label    String
  votes    Int    @default(0)
  orderIdx Int    @default(0)

  vote    Vote         @relation(fields: [voteId], references: [id], onDelete: Cascade)
  records VoteRecord[]

  @@index([voteId])
  @@map("vote_options")
}

model VoteRecord {
  id        String   @id @default(cuid())
  voteId    String
  optionId  String
  userId    String
  createdAt DateTime @default(now())

  vote   Vote       @relation(fields: [voteId], references: [id], onDelete: Cascade)
  option VoteOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([voteId, userId, optionId])
  @@map("vote_records")
}

model Event {
  id       String   @id @default(cuid())
  postId   String   @unique
  startAt  DateTime
  endAt    DateTime
  location String

  post      Post            @relation(fields: [postId], references: [id], onDelete: Cascade)
  attendees EventAttendee[]

  @@map("events")
}

// 求助帖扩展表
model HelpRequest {
  id                String      @id @default(cuid())
  postId            String      @unique
  urgency           HelpUrgency @default(normal)
  solved            Boolean     @default(false) // 是否已解决
  acceptedCommentId String? // 采纳的评论 id(指向 Comment.id)
  bountyPoints      Int         @default(0) // 悬赏积分(发帖时从作者账户扣,采纳时发给被采纳者)
  bountyPaidOut     Boolean     @default(false) // 悬赏是否已发放(避免重复发放)
  solvedAt          DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([urgency, solved, createdAt])
  @@map("help_requests")
}

model EventAttendee {
  eventId   String
  userId    String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@map("event_attendees")
}

// 生命周期 / 成长日志帖扩展表
model Journal {
  id          String           @id @default(cuid())
  postId      String           @unique
  // 这本日志记录的植物对象昵称,例如「我的红宝石」「阳台 9 号」
  subjectName String
  // 关联品种(可选;若关联,可继承品种封面 / 难度等)
  speciesId   String?
  // 起始日(种植/到家/萌芽起算日)
  startDate   DateTime
  // 结束日(死亡 / 送人 / 自然结束;空表示仍在养)
  endDate     DateTime?
  endReason   JournalEndReason @default(alive)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  post    Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  species Species?       @relation(fields: [speciesId], references: [id])
  entries JournalEntry[]

  @@index([speciesId])
  @@map("journals")
}

model JournalEntry {
  id        String       @id @default(cuid())
  journalId String
  entryDate DateTime
  stage     JournalStage @default(other)
  note      String       @db.Text // 心得文本(纯文本/简单 markdown)
  // MySQL TEXT 不允许默认值,空 JSON 在应用层兜底为 "[]"
  images    String       @db.Text // JSON array,封面或多张图
  orderIdx  Int          @default(0) // 同日多条时的次序
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)

  @@index([journalId, entryDate])
  @@map("journal_entries")
}

// ============== 评论 ==============

model Comment {
  id          String   @id @default(cuid())
  postId      String
  authorId    String
  parentId    String?
  // 富文本三套字段
  content     String   @db.Text // 已 sanitize 的 HTML
  contentJson String?  @db.Text // ProseMirror JSON 字符串
  contentText String?  @db.Text // 纯文本(用于通知预览)
  likes       Int      @default(0)
  createdAt   DateTime @default(now())

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies Comment[] @relation("Replies")

  @@index([postId, createdAt])
  @@map("comments")
}

// ============== 交互:点赞、收藏 ==============

model PostLike {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@map("post_likes")
}

model PostCollect {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@map("post_collects")
}

// ============== 私信 ==============

model Message {
  id        String    @id @default(cuid())
  fromId    String
  toId      String
  text      String    @db.Text
  readAt    DateTime?
  createdAt DateTime  @default(now())

  from User @relation("MessageFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   User @relation("MessageTo", fields: [toId], references: [id], onDelete: Cascade)

  @@index([fromId, toId, createdAt])
  @@index([toId, fromId, createdAt])
  @@map("messages")
}

// ============== 通知 ==============

enum NotificationType {
  like
  comment
  follow
  mention
  system
}

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  fromId      String?
  type        NotificationType
  text        String           @db.Text
  link        String?
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  recipient User  @relation("NotifRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  from      User? @relation("NotifSender", fields: [fromId], references: [id])

  @@index([recipientId, createdAt])
  @@map("notifications")
}

// ============== 多肉图鉴 ==============

model Plant {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  latinName   String
  family      String
  cover       String
  difficulty  Int    @default(1)
  light       String
  watering    String
  hardiness   String
  description String @db.Text
  tips        String @db.Text // JSON array
  gallery     String @db.Text // JSON array

  @@map("plants")
}

// ============== 草稿 ==============

model Draft {
  id        String   @id @default(cuid())
  userId    String
  payload   String   @db.LongText // 整个草稿表单的 JSON
  title     String
  type      PostType
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@map("drafts")
}

// ============== Banner ==============

model Banner {
  id         String  @id @default(cuid())
  title      String
  subtitle   String  @db.Text
  image      String
  link       String
  tint       String
  orderIdx   Int     @default(0)
  enabled    Boolean @default(true)
  /// 这一张图停留毫秒数,0 = 用全站默认(3000ms)
  durationMs Int     @default(0)

  @@map("banners")
}

// ============================================================
// 交易系统
// ============================================================

enum ProductSource {
  official // 官方上架
  c2c // 用户二手出售
}

enum ProductStatus {
  on_sale
  sold_out
  off_shelf
  pending_review
}

model Product {
  id              String        @id @default(cuid())
  source          ProductSource
  title           String
  cover           String
  images          String        @db.Text // JSON array
  // 富文本三套字段(描述)
  description     String        @db.LongText // 已 sanitize 的 HTML
  descriptionJson String?       @db.LongText // ProseMirror JSON 字符串
  descriptionText String?       @db.Text // 纯文本
  category        String // 工具/肥料/盆器/盆土/植物/服饰...
  price           Int // 单位:分(避免浮点误差)
  originalPrice   Int? // 划线价
  stock           Int           @default(0) // C2C 默认 1
  pointsBack      Int           @default(0) // 购买可返多少积分
  status          ProductStatus @default(on_sale)
  sellerId        String? // C2C 必填,官方为空
  shipFrom        String? // 发货地
  tags            String?       @db.Text // JSON array
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  seller User?   @relation("ProductSeller", fields: [sellerId], references: [id])
  orders Order[]

  @@index([source, status, createdAt])
  @@index([sellerId])
  @@map("products")
}

enum OrderStatus {
  pending_payment // 待付款
  pending_ship // 待发货(已支付)
  pending_receipt // 待收货
  pending_review // 待评价
  completed // 已完成
  cancelled // 已取消
  refunded // 已退款
}

enum OrderSource {
  product // 普通商品订单
  auction // 由拍卖胜出生成的订单
}

model Order {
  id              String      @id @default(cuid())
  orderNo         String      @unique // 类似 RY20260429xxx
  source          OrderSource @default(product)
  productId       String? // 拍卖订单可能不指向 product(纯拍卖品独立存在)
  auctionId       String? // 当 source=auction 时指向 Auction.id
  buyerId         String
  sellerId        String? // 官方订单为 null
  quantity        Int         @default(1)
  unitPrice       Int
  totalPrice      Int // 单位:分
  depositPaid     Int         @default(0) // 已抵扣的保证金(仅 auction 订单)
  pointsBackTotal Int         @default(0)
  status          OrderStatus @default(pending_payment)

  shipName    String?
  shipPhone   String?
  shipAddress String?

  trackingNo      String?
  shippedAt       DateTime?
  receivedAt      DateTime?
  reviewRating    Int? // 1-5
  // 评价富文本(三套字段)
  reviewText      String?   @db.Text
  reviewTextJson  String?   @db.Text
  reviewTextPlain String?   @db.Text
  reviewedAt      DateTime?
  cancelledAt     DateTime?
  refundReason    String?   @db.Text
  refundedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product? @relation(fields: [productId], references: [id])
  auction Auction? @relation(fields: [auctionId], references: [id])
  buyer   User     @relation("OrderBuyer", fields: [buyerId], references: [id])
  seller  User?    @relation("OrderSeller", fields: [sellerId], references: [id])

  @@index([buyerId, status, createdAt])
  @@index([sellerId, status])
  @@map("orders")
}

enum PaymentChannel {
  wechat
  alipay
  points // 积分支付(VIP 月卡可用)
}

enum PaymentStatus {
  pending
  paid
  expired
  cancelled
  refunded
}

enum PaymentBizType {
  order // 商品订单
  vip // 大会员订阅
  deposit // 拍卖保证金
  auction_balance // 拍卖订单的尾款(本质也是 order,但单独标记便于追溯)
}

model Payment {
  id        String         @id @default(cuid())
  payNo     String         @unique
  bizType   PaymentBizType
  bizId     String // orderId 或 vipOrderId
  userId    String
  channel   PaymentChannel
  amount    Int // 单位:分
  qrcode    String?        @db.Text // Mock 二维码内容/链接
  status    PaymentStatus  @default(pending)
  expireAt  DateTime
  paidAt    DateTime?
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([bizType, bizId])
  @@map("payments")
}

// ============================================================
// 积分系统
// ============================================================

enum PointsEventType {
  signin // 签到
  post_create // 发帖
  post_liked // 被点赞
  comment_create // 评论
  comment_liked // 评论被赞
  followed // 被关注
  task_complete // 完成每日/月度任务
  activity_reward // 月度活跃度阶梯奖励
  purchase_back // 购物返利
  recharge // 充值买积分
  exchange_skin // 兑换皮肤
  exchange_vip // 兑换 VIP
  refund // 订单退款回收
  admin // 运营调整
}

model PointsLedger {
  id        String          @id @default(cuid())
  userId    String
  type      PointsEventType
  delta     Int // 正/负
  balance   Int // 此后余额
  refType   String? // 关联业务类型,如 post/order/skin
  refId     String?
  remark    String?         @db.Text
  createdAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("points_ledger")
}

// ============================================================
// 经验值与等级
// ============================================================

enum ExpEventType {
  signin
  post_create
  post_liked
  post_collected
  comment_create
  followed
  purchase
  vip_open
  admin
}

model ExpLedger {
  id        String       @id @default(cuid())
  userId    String
  type      ExpEventType
  delta     Int
  total     Int // 此后累计 EXP
  refType   String?
  refId     String?
  remark    String?      @db.Text
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("exp_ledger")
}

// ============================================================
// 活跃度系统(月度排行 + 阶梯奖励)
// ============================================================

enum ActivityEventType {
  signin
  post_create
  post_liked
  post_collected
  comment_create
  vote_cast
  purchase
  task_complete
}

model ActivityLedger {
  id        String            @id @default(cuid())
  userId    String
  type      ActivityEventType
  delta     Int // 加权后的活跃度分
  yearMonth String // 形如 "2026-04",方便聚合
  refType   String?
  refId     String?
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, yearMonth])
  @@index([yearMonth])
  @@map("activity_ledger")
}

/**
 * 月度快照(用于历史月排行榜的快速查询;当月通过 ledger 聚合)
 */
model MonthlyActivity {
  id        String   @id @default(cuid())
  userId    String
  yearMonth String // "2026-04"
  score     Int      @default(0)
  rank      Int? // 月末计算
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, yearMonth])
  @@index([yearMonth, score])
  @@map("monthly_activity")
}

// ============================================================
// 任务系统
// ============================================================

enum TaskKind {
  daily // 每日(每天 0 点重置)
  monthly // 月度(每月 1 号重置)
  achievement // 一次性成就(完成即终生)
}

model Task {
  id             String   @id @default(cuid())
  slug           String   @unique
  kind           TaskKind
  title          String
  description    String   @db.Text
  icon           String   @default("🎯")
  rewardPoints   Int      @default(0)
  rewardExp      Int      @default(0)
  rewardActivity Int      @default(0)
  target         Int      @default(1) // 进度目标(发 3 帖、签 7 天等)
  triggerEvent   String // 由哪个事件推动:signin/post_create/comment/...
  enabled        Boolean  @default(true)
  orderIdx       Int      @default(0)

  progress TaskProgress[]

  @@map("tasks")
}

model TaskProgress {
  id          String    @id @default(cuid())
  userId      String
  taskId      String
  cycleKey    String // daily 用 yyyy-MM-dd / monthly 用 yyyy-MM / achievement 用 'always'
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  claimed     Boolean   @default(false)
  completedAt DateTime?
  claimedAt   DateTime?
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId, cycleKey])
  @@index([userId, cycleKey])
  @@map("task_progress")
}

/**
 * 月度活跃度阶梯奖励:活跃度达到 X 即可领
 */
model ActivityReward {
  id           String  @id @default(cuid())
  threshold    Int // 月活跃度门槛
  title        String
  rewardPoints Int     @default(0)
  rewardSkinId String? // 可奖励一个皮肤
  description  String  @db.Text
  orderIdx     Int     @default(0)

  claims ActivityRewardClaim[]

  @@map("activity_rewards")
}

model ActivityRewardClaim {
  id        String   @id @default(cuid())
  userId    String
  rewardId  String
  yearMonth String // 一个用户一个月最多领一次
  createdAt DateTime @default(now())

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward ActivityReward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@unique([userId, rewardId, yearMonth])
  @@index([yearMonth])
  @@map("activity_reward_claims")
}

// ============================================================
// 皮肤 / 装扮
// ============================================================

enum SkinKind {
  bubble // 评论气泡
  reaction // 点赞按钮
  sticker // 表情包套装
  pendant // 头像挂件 / 头像框
}

model SkinItem {
  id          String   @id @default(cuid())
  slug        String   @unique
  kind        SkinKind
  name        String
  preview     String // 预览图 URL 或 emoji
  description String   @db.Text
  pricePoints Int      @default(0) // 兑换积分
  vipOnly     Boolean  @default(false) // 仅大会员可用
  rarity      String   @default("normal") // normal/rare/epic/legendary
  meta        String?  @db.Text // JSON,前端渲染用(颜色/图集等)
  enabled     Boolean  @default(true)
  orderIdx    Int      @default(0)

  owners UserSkin[]

  @@index([kind, enabled, orderIdx])
  @@map("skin_items")
}

model UserSkin {
  userId       String
  skinId       String
  obtainedFrom String // exchange / reward / vip / event
  obtainedAt   DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skin SkinItem @relation(fields: [skinId], references: [id], onDelete: Cascade)

  @@id([userId, skinId])
  @@index([skinId])
  @@map("user_skins")
}

// ============================================================
// 大会员
// ============================================================

enum VipPlan {
  monthly // 月卡
  quarterly // 季卡
  yearly // 年卡
  lifetime // 终身
  monthly_points // 积分兑换月卡
}

model VipOrder {
  id           String      @id @default(cuid())
  orderNo      String      @unique
  userId       String
  plan         VipPlan
  amount       Int // 单位:分;积分卡为 0
  pointsCost   Int         @default(0) // 积分消费数;现金卡为 0
  durationDays Int // 增加多少天
  status       OrderStatus @default(pending_payment) // 复用订单状态枚举
  paidAt       DateTime?
  createdAt    DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("vip_orders")
}

// ============================================================
// 收货地址簿
// ============================================================

model Address {
  id        String   @id @default(cuid())
  userId    String
  name      String // 收件人姓名
  phone     String // 联系电话
  province  String? // 省
  city      String? // 市
  district  String? // 区
  detail    String // 详细地址
  zip       String? // 邮编
  tag       String? // 自定义标签:家 / 公司 / 学校
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isDefault])
  @@map("addresses")
}

// ============================================================
// 拍卖
// ============================================================

enum AuctionStatus {
  draft // 草稿(暂不开启)
  scheduled // 已发布,未开始
  live // 进行中
  finished // 正常结束(已成交或流拍)
  cancelled // 主动取消
}

enum AuctionResult {
  won // 已成交,胜出者待付款 / 已生成订单
  paid // 胜出者已付完余额
  no_bidder // 流拍 - 全程无人出价
  defaulted // 胜出者未付款,违约
  cancelled // 主动取消
}

model Auction {
  id              String  @id @default(cuid())
  sellerId        String // 拍卖发起者(可能是官方或 C2C 用户)
  title           String
  cover           String
  images          String  @db.Text // JSON array
  description     String  @db.LongText // sanitized HTML
  descriptionJson String? @db.LongText
  descriptionText String? @db.Text

  category String // 与商品共享分类体系
  tags     String? @db.Text

  startPrice    Int // 起拍价(分)
  minIncrement  Int  @default(100) // 最小加价幅度,默认 1 元
  buyNowPrice   Int? // 一口价(可选)
  depositAmount Int // 保证金金额(分),发起者设定
  reservePrice  Int? // 保留价,低于此价流拍(可选)

  startAt          DateTime // 开始时间
  endAt            DateTime // 原定结束时间
  actualEndAt      DateTime? // 实际结束(防狙击延长后会更新)
  antiSnipeMinutes Int       @default(5) // 最后 N 分钟出价,延长 N 分钟

  status AuctionStatus  @default(scheduled)
  result AuctionResult?

  currentPrice Int // 当前价(默认 = startPrice)
  bidCount     Int @default(0)

  winnerId       String? // 胜出者
  winningOrderId String? @unique // 胜出订单,创建后回填

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seller       User                 @relation("AuctionSeller", fields: [sellerId], references: [id])
  winner       User?                @relation("AuctionWinner", fields: [winnerId], references: [id])
  bids         Bid[]
  participants AuctionParticipant[]
  orders       Order[]

  @@index([status, endAt])
  @@index([sellerId, status])
  @@index([winnerId])
  @@map("auctions")
}

model Bid {
  id        String   @id @default(cuid())
  auctionId String
  bidderId  String
  amount    Int // 出价金额
  createdAt DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidder  User    @relation("BidUser", fields: [bidderId], references: [id])

  @@index([auctionId, createdAt])
  @@index([auctionId, amount])
  @@index([bidderId])
  @@map("bids")
}

/**
 * 参与者:每个用户在某场拍卖里只参与一次(用于保证金管理)。
 * 首次出价前必须创建参与者并完成保证金支付。
 */
enum DepositStatus {
  pending // 已创建,等待支付保证金
  held // 保证金已入账(冻结中)
  applied // 已抵扣到尾款订单
  refunded // 拍卖结束已退还
  forfeited // 因违约罚没
}

model AuctionParticipant {
  id               String        @id @default(cuid())
  auctionId        String
  userId           String
  depositPaymentId String?       @unique // 保证金支付单 id
  depositStatus    DepositStatus @default(pending)
  depositAmount    Int // 实际付的金额(可能与 auction.depositAmount 不同,但 demo 一致)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User    @relation("AuctionParticipantUser", fields: [userId], references: [id])

  @@unique([auctionId, userId])
  @@index([userId, depositStatus])
  @@map("auction_participants")
}

// ============================================================
// 三级板块分类
//   Category (科 / 分类顶级)
//     └── Genus (属)
//           └── Species (品种 / 子板块,同时承载「多肉图鉴」信息)
//
// 另外 Category 引入 kind 字段,把旧的非分类板块(新手村/交易市场)
// 保留为 family='other' 类的特殊科。
// ============================================================

enum CategoryKind {
  family // 科(植物学分类)
  discussion // 非分类讨论型板块(新手村、养殖交流等)
  market // 交易/活动型板块(若需要)
}

model Category {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String // 如 "仙人掌科"
  latinName   String? // 如 "Cactaceae"
  kind        CategoryKind @default(family)
  description String       @db.Text
  cover       String
  icon        String
  members     Int          @default(0) // 冗余展示,允许不精确
  orderIdx    Int          @default(0)
  enabled     Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  genera Genus[]
  posts  Post[]

  @@index([kind, orderIdx])
  @@map("categories")
}

model Genus {
  id          String   @id @default(cuid())
  categoryId  String
  slug        String // 在所属 category 内唯一
  name        String // 如 "星球属"
  latinName   String? // 如 "Astrophytum"
  description String   @db.Text
  cover       String?
  orderIdx    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  species  Species[]
  posts    Post[]

  @@unique([categoryId, slug])
  @@index([slug])
  @@map("genera")
}

model Species {
  id          String  @id @default(cuid())
  genusId     String
  slug        String
  name        String // 中文俗名
  latinName   String // 拉丁学名
  alias       String? @db.Text // 别名 / 品种系 / 园艺名(JSON array)
  description String  @db.Text

  // 从原 Plant 表迁移的字段:
  cover      String
  gallery    String @db.Text // JSON array
  difficulty Int    @default(2) // 1-5,管理员设的「初始/校准」难度
  light      String // "全日照" / "散射光" ...
  watering   String
  hardiness  String // "-5°C"
  tips       String @db.Text // JSON array

  // 额外图鉴字段
  blooming     String? // 花期
  originRegion String? // 原产地
  growthType   String? // 夏型 / 冬型 / 中间型

  // 用户打分汇总(由 SpeciesRating 触发更新)
  ratingSum   Int @default(0) // 所有打分之和
  ratingCount Int @default(0) // 总打分人数

  posts    Post[]
  ratings  SpeciesRating[]
  journals Journal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  genus Genus @relation(fields: [genusId], references: [id], onDelete: Cascade)

  @@unique([genusId, slug])
  @@index([slug])
  @@index([genusId, name])
  @@map("species")
}

/**
 * 用户对品种的难度打分。
 * 同一用户对同一品种唯一,可以更新或删除(撤回)。
 */
model SpeciesRating {
  id        String   @id @default(cuid())
  userId    String
  speciesId String
  score     Int // 1-5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  species Species @relation(fields: [speciesId], references: [id], onDelete: Cascade)

  @@unique([userId, speciesId])
  @@index([speciesId, createdAt])
  @@map("species_ratings")
}

// ============================================================
// 站点全局配置(管理员可调,前端读)
// ============================================================

model SiteConfig {
  /// 业务键名,如 photoUploadMinLevel / photoUploadVipOnly / photoModeration
  key       String   @id
  /// JSON 字符串值;读取时按 key 类型反序列化
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("site_configs")
}

// ============================================================
// 板块关注(多态:可关注 Category / Genus / Species 任一层级)
// ============================================================

enum BoardFollowType {
  category
  genus
  species
}

model BoardFollow {
  id        String          @id @default(cuid())
  userId    String
  type      BoardFollowType
  targetId  String // 对应 Category.id / Genus.id / Species.id
  createdAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, targetId])
  @@index([userId, createdAt])
  @@index([type, targetId])
  @@map("board_follows")
}

enum UserRole {
  user
  moderator
  admin
}

/**
 * 管理员操作日志
 */
model AdminLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String // e.g. "post.delete", "user.ban", "product.offshelf"
  targetType String // "post" | "user" | "product" | "order" | ...
  targetId   String? // 目标对象 id(可空,比如系统操作)
  meta       Json? // 操作附加信息
  reason     String?  @db.Text
  ip         String?  @db.VarChar(64)
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
  @@map("admin_logs")
}

/**
 * 站内公告
 */
model Announcement {
  id        String    @id @default(cuid())
  title     String
  content   String    @db.Text
  level     String    @default("info") // info | warning | important
  enabled   Boolean   @default(true)
  startAt   DateTime?
  endAt     DateTime?
  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([enabled, createdAt])
  @@map("announcements")
}

/**
 * 用户举报(帖子/评论/用户)
 */
model Report {
  id         String       @id @default(cuid())
  reporterId String? // 可空:匿名举报
  targetType ReportTarget
  targetId   String // 被举报对象 id
  reason     String // 枚举 key,如 "spam" / "abuse" / "pornography"
  detail     String?      @db.Text
  status     ReportStatus @default(pending)
  handledBy  String? // 处理人
  handledAt  DateTime?
  handleNote String?      @db.Text
  createdAt  DateTime     @default(now())

  reporter User? @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@map("reports")
}

enum ReportTarget {
  post
  comment
  user
}

enum ReportStatus {
  pending
  resolved
  rejected
}

/**
 * 帖子浏览记录(用于推荐算法 + 冷启动)。
 * 设计:
 * - 登录用户用 userId,匿名用户用 anonId(cookie 种的 UUID)
 * - 同 (userId | anonId, postId) 24h 内去重(算 UV)
 * - 每次访问都 +1 到 Post.views(通过事务)
 * - 用于推荐算法:计算用户兴趣向量 / 算分时当信号
 */
model PostView {
  id        String   @id @default(cuid())
  postId    String
  userId    String?
  anonId    String?  @db.VarChar(40) // 匿名用户的 cookie UUID
  source    String? // feed_recommend | feed_following | direct | board | search
  dwellMs   Int? // 停留时长(可选,后续埋点补)
  createdAt DateTime @default(now())

  post Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([postId, createdAt])
  @@index([userId, createdAt])
  @@index([anonId, createdAt])
  @@map("post_views")
}
